# Required
GOOGLE_API_KEY=your-google-ai-studio-key

# Optional (shown with defaults)
# Watch and vault default to ./public — the repo's bundled sample vault.
# Point them at your real Obsidian vault when deploying.
WATCH_DIR=./public
VAULT_DIR=./public
DB_PATH=./.data/state.db
LOG_DIR=./logs
API_BASE=https://generativelanguage.googleapis.com/v1beta
# Model defaults (Gemini API model IDs)
LIGHT_MODEL=gemma-4-26b-a4b-it
HEAVY_MODEL=gemma-4-31b-it
# Deprecated alias kept for backwards compatibility. Prefer HEAVY_MODEL.
REASONER_MODEL=gemma-4-31b-it
VISION_MODEL=gemini-3.1-flash-lite-preview
RPM_LIMIT=14
FS_DEBOUNCE_MS=2000
BATCH_TOKEN_TARGET=25000
STATUS_INTERVAL_SECS=300

# Hierarchical index tuning
# INDEX_ENTRY_CAP — max one-liners per index file before it auto-splits.
# TOC_PAGE_BUDGET — leading pages rasterized for the TOC extractor.
INDEX_ENTRY_CAP=20
TOC_PAGE_BUDGET=15

# ---- Multi-agent research layer ----
# Daily call budget (Gemma free tier = 1500 RPD).
RPD_LIMIT=1500
# Role share percentages (must sum to 100).
ROLE_SHARE_EXTRACTOR=60
ROLE_SHARE_CURATOR=20
ROLE_SHARE_BRIDGE=15
ROLE_SHARE_HARVESTER=5
ROLE_SHARE_THEOREM=8
ROLE_SHARE_DERIVATION=7
ROLE_SHARE_REPORT=3
ROLE_SHARE_FORMULA=10
# Optional per-role model overrides (blank = fall back to HEAVY_MODEL).
CURATOR_MODEL=
BRIDGE_MODEL=
THEOREM_MODEL=
DERIVATION_MODEL=
REPORT_MODEL=
# Formula extractor override (blank = fall back to LIGHT_MODEL).
FORMULA_MODEL=
FORMULA_DETECT_TAU=0.12

# Idle scheduler cadence + thresholds.
SCHEDULER_INTERVAL_SECS=60
RESEARCH_INTERVAL_SECS=30
CURATE_DELTA_K=5
HARVEST_EVERY_N=25
RESEARCH_API_BIND=127.0.0.1:8090
THINKING_REDACTION_POLICY=redact
THINKING_MAX_BYTES=2048

# Bridge agent tuning.
BRIDGE_MAX_PENDING=6
BRIDGE_MAX_ITERS=3
BRIDGE_CONFIDENCE_TAU=0.72
# Mid-band candidate selection (entity/note overlap).
BRIDGE_MIN_OVERLAP=1
BRIDGE_MAX_OVERLAP=5
BRIDGE_MAX_JACCARD=0.6

# ---- Tavily literature search (Bridge iter 2) ----
# Leave TAVILY_API_KEY blank to disable external citations entirely.
TAVILY_API_KEY=
TAVILY_ENDPOINT=https://api.tavily.com/search
TAVILY_MONTHLY_LIMIT=1000
TAVILY_DAILY_SOFT_CAP=33
TAVILY_PER_BRIDGE_CAP=1
TAVILY_MAX_RESULTS=5
TAVILY_DOMAINS=arxiv.org,semanticscholar.org,dl.acm.org,link.springer.com,nature.com,sciencedirect.com

# Error retrier cadence / limits.
ERROR_RETRY_INTERVAL_SECS=300
ERROR_RETRY_MAX=3
ERROR_RETRY_BACKOFF_SECS=300
ERROR_RETRY_BATCH=20

# Research-stage thresholds.
THEOREM_CONFIDENCE_TAU=0.85
THEOREM_ENQUEUE_BATCH=2
REPORT_INTERVAL_SECS=86400
DERIVATION_MIN_FORMULAS=3

# Log verbosity (tracing EnvFilter syntax)
RUST_LOG=edge_kg_agent=info,pdf_oxide=error,warn

# ---- OpenTelemetry (optional) ----
# Leave OTEL_EXPORTER_OTLP_ENDPOINT blank to disable OTel export entirely.
# For local Jaeger (see deploy/otel/docker-compose.yml):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
# UI then available at http://127.0.0.1:16686
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=edge-kg-agent
# Comma-separated k=v pairs, e.g. deployment.environment=dev,host.name=pi
OTEL_RESOURCE_ATTRIBUTES=
