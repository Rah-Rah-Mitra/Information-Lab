# Required
GOOGLE_API_KEY=your-google-ai-studio-key

# Optional (shown with defaults)
# Watch and vault default to ./public — the repo's bundled sample vault.
# Point them at your real Obsidian vault when deploying.
WATCH_DIR=./public
VAULT_DIR=./public
DB_PATH=./.data/state.db
LOG_DIR=./logs
API_BASE=https://generativelanguage.googleapis.com/v1beta
REASONER_MODEL=gemma-4-31b-it
VISION_MODEL=gemini-3.1-flash-lite-preview
RPM_LIMIT=14
FS_DEBOUNCE_MS=2000
BATCH_TOKEN_TARGET=25000
STATUS_INTERVAL_SECS=300

# Hierarchical index tuning
# INDEX_ENTRY_CAP — max one-liners per index file before it auto-splits.
# TOC_PAGE_BUDGET — leading pages rasterized for the TOC extractor.
INDEX_ENTRY_CAP=20
TOC_PAGE_BUDGET=15

# Log verbosity (tracing EnvFilter syntax)
RUST_LOG=edge_kg_agent=info,warn

# ---- OpenTelemetry (optional) ----
# Leave OTEL_EXPORTER_OTLP_ENDPOINT blank to disable OTel export entirely.
# For local Jaeger (see deploy/otel/docker-compose.yml):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
# UI then available at http://127.0.0.1:16686
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=edge-kg-agent
# Comma-separated k=v pairs, e.g. deployment.environment=dev,host.name=pi
OTEL_RESOURCE_ATTRIBUTES=
