# Required
WATCH_DIR=/home/pi/Sync/PDFs
VAULT_DIR=/home/pi/Obsidian/Vault
GOOGLE_API_KEY=your-google-ai-studio-key

# Optional — enables the deep-research agent (web_search tool). Leave blank to disable.
TAVILY_API_KEY=

# Optional (shown with defaults)
DB_PATH=./state.db
LOG_DIR=./logs
API_BASE=https://generativelanguage.googleapis.com/v1beta
REASONER_MODEL=gemma-4-31b-it
VISION_MODEL=gemini-3.1-flash-lite-preview
RPM_LIMIT=14
FS_DEBOUNCE_MS=2000
BATCH_TOKEN_TARGET=25000
STATUS_INTERVAL_SECS=300

# Log verbosity (tracing EnvFilter syntax)
RUST_LOG=edge_kg_agent=info,warn

# ---- OpenTelemetry (optional) ----
# Leave OTEL_EXPORTER_OTLP_ENDPOINT blank to disable OTel export entirely.
# Common local collector endpoints: http://127.0.0.1:4317 (gRPC) / http://127.0.0.1:4318 (HTTP)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=edge-kg-agent
# Comma-separated k=v pairs, e.g. deployment.environment=dev,host.name=pi
OTEL_RESOURCE_ATTRIBUTES=
